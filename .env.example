# Database
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=payments
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/payments

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# API
API_KEY=test-api-key-12345
API_PORT=8000

# Outbox
OUTBOX_POLL_INTERVAL=5
MAX_RETRIES=3
WEBHOOK_TIMEOUT=10